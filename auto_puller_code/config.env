# ==========================================
# AUTO-PULL CONFIGURATION
# ==========================================

# 1. Repository Settings
# The absolute path to your project code in WSL
PROJECT_DIR="/home/user/path/to/your/project"

# The branch you want to track and pull
BRANCH="main"

# 2. Logging Settings
# Name of the log file (will be created in the same folder as this config)
LOG_FILE="script.logs"
DEBUG_LOG_FILE="debug.logs"

# 3. Deployment Settings
# Set to "true" to enable automatic Docker rebuilds after a successful pull
ENABLE_DOCKER="true"
DOCKER_COMMAND="docker compose down && docker compose up -d --build"

# 4. SSH Configuration (For Background Cron Jobs)
# Cron cannot enter SSH passphrases interactively. Generate a dedicated Deploy Key 
# with NO passphrase using the command below, then provide its path here.
# Command: ssh-keygen -t ed25519 -f ~/.ssh/deploy_key -N ""
SSH_KEY_PATH="/home/user/.ssh/deploy_key"

# Optional: Add any pre-pull or post-pull commands here if needed in the future
